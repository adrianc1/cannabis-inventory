<div class="max-w-4xl mx-auto my-8">
    <h2 class="text-2xl font-bold mb-4 text-gray-800">Inventory Transaction History</h2>
    <p class="text-sm text-gray-500 mb-4">Detailed audit trail of all inventory movements for this product.</p>

    <div class="overflow-hidden border border-gray-300 rounded-lg shadow-sm">
        <table class="w-full border-collapse bg-white">
            <thead>
                <tr class="bg-gray-200 text-left text-xs uppercase tracking-wider text-gray-700">
                    <th class="px-4 py-3 border-b border-gray-300">Package Details</th>
                    <th class="px-4 py-3 border-b border-gray-300">Location</th>
                    <th class="px-4 py-3 border-b border-gray-300">Current Qty</th>
                    <th class="px-4 py-3 border-b border-gray-300">Total Value</th>
                    <th class="px-4 py-3 border-b border-gray-300">Status</th>
                    <th class="px-4 py-3 border-b border-gray-300 text-right">Audit</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                <% packages.forEach(package => { %>
                    <% 
                        const statusClasses = { 
                            active: 'bg-green-100 text-green-800',
                            inactive: 'bg-gray-200 text-gray-700',
                            quarantine: 'bg-yellow-100 text-yellow-800',
                            damaged: 'bg-red-100 text-red-800',
                        };
                        const statusClass = statusClasses[package.status] || 'bg-gray-100 text-gray-800';
                    %>

                    <tr class="bg-gray-50 hover:bg-white transition-colors">
                        <td class="px-4 py-3 font-mono text-sm text-emerald-800 font-bold">
                            <%= package.package_tag %>
                        </td>
                        <td class="px-4 py-3 text-sm text-gray-600">
                            <%= package.location || 'Unassigned' %>
                        </td>
                        <td class="px-4 py-3 text-sm font-semibold">
                            <%= package.quantity %> <span class="text-gray-400 font-normal"><%= package.package_unit || '' %></span>
                        </td>
                        <td class="px-4 py-3 text-sm font-semibold text-gray-700">
                            $<%= (Number(package.quantity) * Number(package.cost_price || 0)).toFixed(2) %>
                        </td>
                        <td class="px-4 py-3">
                            <span class="inline-block px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide <%= statusClass %>">
                                <%= package.status %>
                            </span>
                        </td>
                        <td class="px-4 py-3 text-right">
                            <button 
                                class="toggle-audit-btn text-xs font-bold text-blue-600 hover:text-blue-800 flex items-center justify-end gap-1 w-full cursor-pointer"
                                data-id="<%= package.package_id %>"
                            >
                                <span>View History</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                </svg>
                            </button>
                        </td>
                    </tr>

                    <tr id="audit-<%= package.package_id %>" class="hidden bg-white">
                        <td colspan="6" class="px-8 py-4 bg-gray-50/50">
                            <div class="border rounded-md overflow-hidden shadow-inner">
                                <table class="w-full text-left">
                                    <thead class="bg-gray-100 text-[10px] uppercase text-gray-500 font-bold">
                                        <tr>
                                            <th class="px-4 py-2">Timestamp</th>
                                            <th class="px-4 py-2">Authorized User</th>
                                            <th class="px-4 py-2">Transaction Type</th>
                                            <th class="px-4 py-2">Change</th>
                                            <th class="px-4 py-2">Notes</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-100">
                                        <% if (package.movements && package.movements.length > 0) { %>
                                            <% package.movements.forEach(mv => { %>
                                                <tr class="text-xs">
                                                    <td class="px-4 py-2 text-gray-500 whitespace-nowrap">
                                                        <%= new Date(mv.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                                                    </td>
                                                    <td class="px-4 py-2 font-medium"><%= mv.user_name %></td>
                                                    <td class="px-4 py-2">
                                                        <span class="capitalize"><%= mv.movement_type %></span>
                                                    </td>
                                                    <td class="px-4 py-2 font-bold <%= mv.quantity > 0 ? 'text-green-600' : 'text-red-600' %>">
                                                        <%= mv.quantity > 0 ? '+' : '' %><%= mv.quantity %>
                                                    </td>
                                                    <td class="px-4 py-2 text-gray-400 italic">
                                                        <%= mv.notes || '--' %>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="5" class="px-4 py-4 text-center text-gray-400 italic text-xs">No transaction history recorded for this package.</td>
                                            </tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.toggle-audit-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const id = btn.dataset.id;
                const auditRow = document.getElementById(`audit-${id}`);
                const svg = btn.querySelector('svg');
                
                auditRow.classList.toggle('hidden');
                
                if (auditRow.classList.contains('hidden')) {
                    svg.style.transform = 'rotate(0deg)';
                } else {
                    svg.style.transform = 'rotate(180deg)';
                }
            });
        });
    });
</script>