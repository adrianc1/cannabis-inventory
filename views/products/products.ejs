<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<link href="/tailwind.css" rel="stylesheet" />

		<title>Products Page</title>
	</head>
	<body class="md:px-4">

		<%- include ('../partials/header.ejs') %>

		<div class="mb-8 mt-4 relative">
			<h1
				class="absolute left-1/2 -translate-x-1/2 top-1/2 -translate-y-1/2 text-3xl font-bold text-gray-800"
			>
				<%= message %>
			</h1>
		</div>
		<div class="main-buttons">
			<a href="/packages/create-product" class="btn-primary">Add New Product</a>
            <a href="/packages/receive" class="btn-secondary">Receive</a>
		</div>

		<table class="products-table w-full border-collapse">
    <tr class="products-table-headers bg-gray-200 text-left">
        <th class="px-3 py-2 border border-gray-300">Package Tag</th>
        <th class="px-3 py-2 border border-gray-300">Product</th>
        <th class="px-3 py-2 border border-gray-300">Quantity</th>
        <th class="px-3 py-2 border border-gray-300">Category</th>
        <th class="px-3 py-2 border border-gray-300">Status</th>
        <th class="px-3 py-2 border border-gray-300 sm:hidden">Avg Cost</th>
        <th class="px-3 py-2 border border-gray-300">Total Val.</th>
        <th class="px-3 py-2 border border-gray-300">Source Tag</th>
        <th class="px-3 py-2 border border-gray-300">Actions</th>
    </tr>

    <% packages.forEach((pkg, i) => { %>
        <% 
          // Color Mapping Logic
          const statusClasses = { 
            active: 'bg-green-100 text-green-800',
            inactive: 'bg-gray-200 text-gray-700',
            quarantine: 'bg-yellow-100 text-yellow-800',
            damaged: 'bg-red-100 text-red-800',
            expired: 'bg-orange-100 text-orange-800',
            reserved: 'bg-blue-100 text-blue-800',
          };
          const statusClass = statusClasses[pkg.status] || 'bg-gray-100 text-gray-800';
        %>

        <tr class="product-row hover:bg-gray-200 <%= i % 2 === 0 ? 'bg-white' : 'bg-gray-100' %>">
            <td class="px-3 py-2 border border-gray-300 font-mono text-xs ">
                <div >
                    <%= pkg.package_tag %>
                </div>
            </td>

            <td class="px-3 py-2 border border-gray-300">
                <a href="/packages/<%= pkg.product_id %>" class="text-blue-600 hover:underline">
                    <%= pkg.product_name %>
                </a>

                <div class="text-xs text-gray-400"><%= pkg.strain_name || 'No Strain' %></div>
            </td>

            <td class="px-3 py-2 border border-gray-300 font-bold">
                <%= pkg.quantity %> <%= pkg.unit || 'each' %>
            </td>

            <td class="px-3 py-2 border border-gray-300 font-bold">
                <a href="/categories/<%= pkg.category_id %>"><%= pkg.category_name %></a>
            </td>

            <td class="px-3 py-2 border border-gray-300">
                <span class="inline-block px-2 py-1 rounded-full text-xs font-medium capitalize <%= statusClass %>">
                    <%= pkg.status %>
                </span>
            </td>
            


            <td class="px-3 py-2 border border-gray-300 sm:hidden text-gray-500">
                $<%= Number(pkg.cost_price || 0).toFixed(2) %>
            </td>
            
            <td class="px-3 py-2 border border-gray-300 font-semibold text-green-700">
                $<%= (Number(pkg.quantity) * Number(pkg.cost_price || 0)).toFixed(2) %>
            </td>

            <td class="px-3 py-2 border border-gray-300 text-xs text-gray-500">
                <% if (pkg.parent_package_tag) { %>
                    <span title="<%= pkg.parent_package_tag %>">
                        ...<%= pkg.parent_package_tag.slice(-6) %>
                    </span>
                <% } else { %>
                    <span class="italic text-gray-400">Direct Intake</span>
                <% } %>
            </td>



            <td class="px-3 py-2 border border-gray-300">
                <div class="flex space-x-2">
                    <a href="/packages/<%= pkg.id %>/adjust/<%=pkg.lot_number%>" class="text-xs text-gray-600 hover:text-black cursor-pointer">Adjust</a>
                    <% if (Number(pkg.quantity) > 0) { %>
                        <% console.log(pkg) %>
                        <a href="/packages/<%= pkg.id %>/split/<%=pkg.lot_number%>" class="text-xs text-blue-600 hover:text-blue-800 font-semibold cursor-pointer">Split</a>
                    <% } %>
                </div>
            </td>
        </tr>
    <% }) %>
</table>
	</body>
</html>
