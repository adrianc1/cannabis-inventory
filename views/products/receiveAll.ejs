<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link href="/tailwind.css" rel="stylesheet" />
		<title>Receive Product</title>
	</head>
	<body class="bg-gray-50 min-h-screen">
		<%- include ('../partials/header.ejs') %>

		<form
		    method="POST"
			action="/packages/receive"
			id="receive-form"
			class="space-y-6 px-8"
		>
			<div class="flex items-center gap-2">
				<p class="text-md font-semibold text-gray-700">Product Name:</p>
				<div class="text-2xl font-bold text-emerald-800">
					<select name="product-select" id="product-select">
						<option>-- Select a Product --</option>
                                <% products.forEach((p, index) => { %>
                                <option value="<%= p.id %>"
									data-description="<%= p.description || 'No description available' %>"
									data-brand="<%= p.brand_name || 'No Brand' %>"
									data-strain="<%= p.strain_name || 'No Strain' %>"
									data-category="<%= p.category_name || 'No Category' %>"
									data-unit="<%= p.unit %>"
									data-product_id="<%= p.id %>"><%= p.name %></option>
                                <% }) %>
					</select>
				</div>
			</div>

			<div class="">
				<p class="text-md font-semibold text-gray-700">Description:</p>
				<div id="display-description" class="text-lg text-gray-800"></div>
			</div>
			<div class="hidden">
				<p class="text-md font-semibold text-gray-700">product_id:</p>
				<div id="display-product_id" class="text-lg text-gray-800"></div>
			</div>

			<div class="grid gap-4">
				<div class="w-full flex justify-between">
					<div class="">
						<p class="text-md font-semibold text-gray-800">Brand:</p>
						<div id="display-brand" class="text-lg text-gray-800">-</div>
					</div>
					<div class="">
						<p class="text-md font-semibold text-gray-800">Strain:</p>
						<div id="display-strain" class="text-lg text-gray-800">-</div>
					</div>
					<div class="">
						<p class="text-md font-semibold text-gray-800">Category:</p>
						<div id="display-category" class="text-lg text-gray-800">-</div>
					</div>
					<div class="">
						<p class="text-md font-semibold text-gray-800">Unit of Measure:</p>
						<div id="display-UoM" class="text-lg text-gray-800">-</div>
					</div>
				</div>

				 <div>
                        <label for="package_tag" class="block text-sm font-semibold text-gray-700 mb-2">
                                Package Tag
                        </label>
                        <input
                         type="text"
                         name="package_tag"
                         id="package_tag"
                         value=""
                         required
                         class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:border-green-600 focus:outline-none transition-colors bg-white"
                        >
                        </div>

				<div class="">
					<label
						for="quantity"
						class="block text-sm font-semibold text-gray-700 mb-2"
					>
						Quantity
				 <div id="display-UoM" class="text-lg text-gray-800">-</div>

					</label>

					<input
						type="number"
						name="quantity"
						id="quantity"
						value="0"
						required
						class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:border-green-600 focus:outline-none transition-colors bg-white"
					/>						
				</div>
				

			
				<div id="package-size-container" class="hidden">
					<input type="hidden" name="product_id" id="product_id">
					<input type="hidden" name="unit" id="unit">
					<label
						for="package_size"
						class="block text-sm font-semibold text-gray-700 mb-2"
					>
						Weight per Unit (g)
						<span class="text-xs font-normal text-gray-500"
							>(e.g., 3.5 for a 1/8th jar)</span>
					</label>
					<input
						type="number"
						name="package_size"
						id="package_size"
						step="0.01"
						placeholder="3.5"
						class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:border-green-600 focus:outline-none transition-colors bg-white"
					/>
				</div>

				<div>
					<label
						for="unit_price"
						class="block text-sm font-semibold text-gray-700 mb-2"
					>
						Unit Price ($)
					</label>
					<input
						type="number"
						name="unit_price"
						id="unit_price"
						step="0.01"
						min="0"
						placeholder="0.00"
						required
						class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:border-green-600 focus:outline-none transition-colors bg-white"
					/>
				</div>
				<div>
					<label
						for="quantity"
						class="block text-sm font-semibold text-gray-700 mb-2"
					>
						Vendor/Supplier
					</label>
					<input
						type="text"
						name="vendor"
						id="vendor"
						placeholder="Big Weed Holdings"
						required
						class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:border-green-600 focus:outline-none transition-colors bg-white"
					/>
				</div>
				<div>
					<label
						for="quantity"
						class="block text-sm font-semibold text-gray-700 mb-2"
					>
						Batch Number
					</label>
					<input
						type="text"
						name="batch"
						id="batch"
						placeholder="CCK091827"
						required
						class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:border-green-600 focus:outline-none transition-colors bg-white"
					/>
				</div>
			</div>

			<div>
				<label class="block text-sm font-semibold text-gray-700 mb-2">
					Reason:
				</label>
				<p class="text-lg text-gray-800 font-medium"></p>

				<input type="hidden" name="reason" value="Receive" />
			</div>

			      <div>
                            <label for="location_id" class="block text-sm font-semibold text-gray-700 mb-2">
                                Location
                            </label>
                            <select
                                name="location_id"
                                id="location_id"
                                class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:border-green-600 focus:outline-none transition-colors bg-white"
                            >
                                <% locations.forEach((loc) => { %>
                                <option value="<%= loc.id %>"><%= loc.name %></option>
                                <% }) %>
                            </select>
                        </div>

			<div>
				<label
					for="notes"
					class="block text-sm font-semibold text-gray-700 mb-2"
				>
					Notes:
				</label>
				<textarea
					id="notes"
					name="notes"
					rows="3"
					placeholder="Additional notes"
					class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg focus:border-green-600 focus:outline-none transition-colors resize-none"
				></textarea>
			</div>

			<div class="flex gap-3 pt-4">
				<button type="submit" id="receive-btn" class="btn-primary flex-1">
					Update Quantity
				</button>
				<a href="/packages/" class="btn-secondary flex-1 text-center">
					Cancel
				</a>
			</div>
		</form>
		<script>
		document.addEventListener('DOMContentLoaded', () => {



				const packageSizeContainer = document.getElementById('package-size-container');
				const productSelect = document.getElementById('product-select');
				const displayDesc = document.getElementById('display-description');
				const displayBrand = document.getElementById('display-brand');
				const displayStrain = document.getElementById('display-strain');
				const displayCategory = document.getElementById('display-category');
				const displayUnit = document.getElementById('display-UoM');
				const unitInput = document.getElementById('unit');
				const product_id = document.getElementById('product_id');


				productSelect.addEventListener('change', (e) => {
					const selectedOption = e.target.options[e.target.selectedIndex];
					// select fixed field elements								
					const desc = selectedOption.dataset.description
					const brand = selectedOption.dataset.brand;
					const strain = selectedOption.dataset.strain;
					const category = selectedOption.dataset.category;
					const unit = selectedOption.dataset.unit
					const pId = selectedOption.dataset.product_id


			
					// update ui
					displayDesc.textContent = desc;
					displayBrand.textContent = brand;
					displayStrain.textContent = strain;
					displayCategory.textContent = category;
					displayUnit.textContent = unit;
					unitInput.value = unit || '';
					product_id.value = pId || 'shit'
					displayUnit.value = unit

					

					if (unitInput) {
						unitInput.value = unit; 
					}

					if (unit && unit.toLowerCase() !== 'each') {
					packageSizeContainer.classList.add('hidden');
					} else {
					packageSizeContainer.classList.remove('hidden');
					}
				});
			});
		</script>
				<!-- <script src="/js/receiveInventory.js"></script> -->

	</body>
</html>
